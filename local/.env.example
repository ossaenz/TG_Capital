# ─────────────────────────────────────────────────────────────────────────────
# TG-Capital Local — Environment Configuration
# Copy this file to ".env" and fill in your own values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Schwab API Credentials ────────────────────────────────────────────────────
# Get these from https://developer.schwab.com → My Apps → your app
# App Key    → SCHWAB_CLIENT_ID
# App Secret → SCHWAB_CLIENT_SECRET
SCHWAB_CLIENT_ID=YOUR_SCHWAB_APP_KEY_HERE
SCHWAB_CLIENT_SECRET=YOUR_SCHWAB_APP_SECRET_HERE

# ── Ollama (AI) ───────────────────────────────────────────────────────────────
# Where Ollama is running. If Ollama is on the same machine as Docker, leave as-is.
# If Ollama is on a different machine, change to http://<ip>:11434
OLLAMA_HOST=http://host.docker.internal:11434

# ── AI Models (optional overrides) ───────────────────────────────────────────
# Chat model — pull first: ollama pull 0xroyce/plutus
CHAT_MODEL=0xroyce/plutus

# Embedding model — auto-detected. Uncomment to force a specific one:
# ollama pull mxbai-embed-large
# EMBED_MODEL=mxbai-embed-large
